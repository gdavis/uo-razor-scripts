
# ship hold check 

if not varexist shipHold or shipHold = 0
    overhead 'Select your ship loot hold:' 54
    setvar shipHold 0
    setvar! shipHold
endif

if shipHold = 0
    overhead 'Invalid ship hold! Retarget!' 38
else 
    # check name to make sure the trash 
    # or something wasnt targetted
    getlabel shipHold holdName
    
    if 's hold' in holdName
    else
        overhead 'Invalid ship hold! Retarget!' 38
        setvar shipHold 0
        loop
    endif
endif


# define loots 

removelist boatLoot
createlist boatLoot
pushlist boatLoot 'doubloon'
pushlist boatLoot 'gold coin'


# drop it all off

if find "shipHold" ground -1 -1 2 as hold
    overhead 'Filling the hold...' 69

    dclick hold
    wait 250

    foreach itemID in boatLoot
        while findtype itemID backpack as booty
            lift booty 60000
            drop hold -1 -1 -1
            while queued
                //dotnothing
            endwhile
        endwhile
    endfor
else
    overhead 'Could not reach the hold!' 34
endif

overhead 'Done filling hold' 69